{
  "$comment": "Architectural fitness rules for codewatch. Run with `code-style graph check`. Thresholds chosen against the post-M20 baseline. M26: glob excludes replaced with role-based excludes — a single `excludeRoles: [\"test\", \"fixture\"]` is more semantic than `**/__tests__/**` and survives a directory rename.",
  "rules": [
    {
      "id": "max-file-loc",
      "type": "metric-max",
      "metric": "loc",
      "kind": "file",
      "max": 500,
      "excludeRoles": ["test", "fixture"]
    },
    {
      "id": "max-cyclomatic-per-function",
      "type": "metric-max",
      "metric": "cyclomatic_max",
      "kind": "file",
      "max": 30,
      "excludeRoles": ["test", "fixture"]
    },
    {
      "id": "max-nesting-depth",
      "type": "metric-max",
      "metric": "max_nesting_depth",
      "kind": "file",
      "max": 5,
      "excludeRoles": ["test", "fixture"]
    },
    {
      "id": "max-fan-out-per-file",
      "type": "metric-max",
      "metric": "fan_out",
      "kind": "file",
      "max": 15,
      "excludeRoles": ["barrel", "test"]
    },
    {
      "id": "render-no-cli-deps",
      "type": "forbid-import",
      "from": "render/**",
      "to": "cli/**"
    },
    {
      "id": "graph-no-cli-deps",
      "type": "forbid-import",
      "from": "graph/**",
      "to": "cli/**"
    },
    {
      "id": "core-no-downstream-deps",
      "type": "forbid-import",
      "from": "core/**",
      "to": "analyzer/**"
    },
    {
      "$comment": "Textbook scary-hotspot signal: high churn × high branching = the riskiest file to touch. Warning-only on this young repo (most 'churn' is bootstrap, not maintenance burden); promote to error once steady-state arrives.",
      "id": "scary-hotspots",
      "type": "metric-product-max",
      "metrics": ["churn_30d", "cyclomatic_max"],
      "max": 1500,
      "kind": "file",
      "severity": "warning",
      "excludeRoles": ["test", "fixture"]
    }
  ]
}
