{
  "name": "@code-style/cli",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "code-style": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint not configured yet'"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@code-style/analyzer": "workspace:*",
    "@code-style/checker": "workspace:*",
    "@code-style/graph": "workspace:*",
    "@code-style/profile": "workspace:*",
    "@code-style/render": "workspace:*",
    "@inquirer/prompts": "^8.3.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.2"
  }
}
