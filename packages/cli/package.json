{
  "name": "@codewatch/cli",
  "version": "0.1.0",
  "description": "Analyze code structure, drift, and architecture from your terminal",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "codewatch": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./read-api": {
      "import": "./dist/read-api/index.js",
      "types": "./dist/read-api/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "codewatch",
    "code-analysis",
    "dependency-graph",
    "architecture",
    "static-analysis",
    "code-quality",
    "cli"
  ],
  "author": "Henry Jewkes",
  "license": "MIT",
  "homepage": "https://github.com/HJewkes/codewatch#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HJewkes/codewatch.git",
    "directory": "packages/cli"
  },
  "bugs": "https://github.com/HJewkes/codewatch/issues",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint not configured yet'"
  },
  "dependencies": {
    "@codewatch/analyzer": "workspace:*",
    "@codewatch/checker": "workspace:*",
    "@codewatch/graph": "workspace:*",
    "@codewatch/profile": "workspace:*",
    "@codewatch/render": "workspace:*",
    "@inquirer/prompts": "^8.3.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.2"
  }
}
