{
  "name": "codewatch-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Static, single-file project-status dashboard for a codewatch graph snapshot. Consumes `graph report --json`; built with React + @titan-design/react-ui, bundled to one self-contained HTML.",
  "scripts": {
    "build": "vite build",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "data": "node scripts/build-data.mjs",
    "shots": "node scripts/screenshots.mjs"
  },
  "dependencies": {
    "@titan-design/react-ui": "^0.2.7",
    "lucide-react": "^0.400.0",
    "nativewind": "^4.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-native-svg": "^15.0.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "tailwindcss": "3.4.17",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.0.0"
  }
}
